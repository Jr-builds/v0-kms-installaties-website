# Offerteformulier e-mail (issue #9)
# Maak gratis account op https://resend.com en kopieer je API key.

RESEND_API_KEY=

# Standaard: info@kmsinstallaties.nl (via lib/business.ts)
OFFERTE_RECIPIENT_EMAIL=info@kmsinstallaties.nl

# Resend test-afzender; na domeinverificatie bijv.:
# OFFERTE_FROM_EMAIL=KMS Installaties <offerte@kmsinstallaties.nl>
OFFERTE_FROM_EMAIL=KMS Installaties <onboarding@resend.dev>

# Supabase (contentbeheer: foto's + later teksten)
# Project Settings → API in het Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://jouw-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
